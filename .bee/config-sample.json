{
  "hooks": {
    "session-init": true,
    "prompt-context": true,
    "write-guard": true,
    "state-sync": true,
    "chain-nudge": true,
    "session-close": true
  },
  "guards": {
    "idle_gate": true
  },
  "lanes": {},
  "capabilities": {},
  "commands": {
    "setup": "npm install",
    "start": "npm run dev",
    "test": "npm test",
    "verify": "npm run build"
  },
  "gate_bypass": false,
  "models": {
    "claude": {
      "extraction": "haiku",
      "generation": {
        "model": "sonnet",
        "effort": "medium"
      },
      "review": "opus",
      "advisor": "fable"
    },
    "codex": {
      "extraction": null,
      "generation": null,
      "review": {
        "kind": "cli",
        "command": "codex exec -m gpt-5.6-sol --yolo -c model_reasoning_effort=\"high\"  workspace-write"
      },
      "advisor": null
    }
  },
  "dogfood_repos": [
    {
      "path": "../example-bee-repo",
      "label": "example-bee-repo"
    }
  ]
}
