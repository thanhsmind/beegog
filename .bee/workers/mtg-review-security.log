    23	async function readStdinPayload() {
    24	  const chunks = [];
    25	  try {
    26	    for await (const chunk of process.stdin) {
    27	      chunks.push(chunk);
    28	    }
    29	  } catch {
    30	    return {};
    31	  }
    32	  const raw = Buffer.concat(chunks).toString("utf8");
    33	  try {
    34	    return JSON.parse(raw || "{}");
    35	  } catch {
    36	    return {};
    37	  }
    38	}
    39	
    40	function findRepoRoot(startDir) {
    41	  let candidate = path.resolve(startDir || process.cwd());
    42	  while (true) {
    43	    if (fs.existsSync(path.join(candidate, ".bee", "onboarding.json"))) {
    44	      return candidate;
    45	    }
    46	    const parent = path.dirname(candidate);
    47	    if (parent === candidate) {
    48	      return null;
    49	    }
    50	    candidate = parent;
    51	  }
    52	}
    53	
    54	function logCrash(root, error) {
    55	  try {
    56	    const logsDir = path.join(root, ".bee", "logs");
    57	    fs.mkdirSync(logsDir, { recursive: true });
    58	    fs.appendFileSync(
    59	      path.join(logsDir, "hooks.jsonl"),
    60	      `${JSON.stringify({
    61	        ts: new Date().toISOString(),
    62	        hook: HOOK_NAME,
    63	        error: String((error && error.stack) || error),
    64	      })}\n`,
    65	    );
    66	  } catch {
    67	    // fail-open
    68	  }
    69	}
    70	
    71	function logDeny(root, toolName, toolInput) {
    72	  try {
    73	    const logsDir = path.join(root, ".bee", "logs");
    74	    fs.mkdirSync(logsDir, { recursive: true });
    75	    fs.appendFileSync(
    76	      path.join(logsDir, "hooks.jsonl"),
    77	      `${JSON.stringify({
    78	        ts: new Date().toISOString(),
    79	        hook: HOOK_NAME,
    80	        event: "deny",
    81	        tool_name: toolName,
    82	        tool_input_keys: Object.keys(toolInput),
    83	      })}\n`,
    84	    );
    85	  } catch {
    86	    // never block the deny itself on a log failure
    87	  }
    88	}
    89	
    90	function libModuleUrl(root, name) {
    91	  return pathToFileURL(path.join(root, ".bee", "bin", "lib", name)).href;
    92	}
    93	
    94	function hasTierMarker(toolInput) {
    95	  const description = typeof toolInput.description === "string" ? toolInput.description : "";
    96	  if (TIER_MARKER_RE.test(description)) {
    97	    return true;
    98	  }
    99	  const prompt = typeof toolInput.prompt === "string" ? toolInput.prompt : "";
   100	  const window = prompt.slice(0, PROMPT_WINDOW);
   101	  return TIER_MARKER_RE.test(window);
   102	}
   103	
   104	async function main() {
   105	  const payload = await readStdinPayload();
   106	  const root = findRepoRoot(payload.cwd || process.cwd());
   107	  if (!root) {
   108	    return 0;
   109	  }
   110	  if (!fs.existsSync(path.join(root, ".bee", "bin", "lib", "state.mjs"))) {
   111	    return 0;
   112	  }
   113	
   114	  const toolName = payload.tool_name || payload.toolName || "";
   115	  if (!DISPATCH_TOOLS.has(toolName)) {
   116	    return 0;
   117	  }
   118	
   119	  let denial = null; // { reason, toolInput }
   120	  try {
   121	    const stateLib = await import(libModuleUrl(root, "state.mjs"));
   122	    if (!stateLib.hookEnabled(root, HOOK_NAME)) {
   123	      return 0;
   124	    }
   125	
   126	    // FAIL-OPEN PRECISION: an absent or non-object tool_input can never reach
   127	    // the deny branch — silent exit 0, no stderr.
   128	    const rawToolInput = payload.tool_input;
   129	    if (!rawToolInput || typeof rawToolInput !== "object" || Array.isArray(rawToolInput)) {
   130	      return 0;
   131	    }
   132	    const toolInput = rawToolInput;
   133	
   134	    if (typeof toolInput.model === "string" && toolInput.model.trim()) {
   135	      return 0;
   136	    }
   137	    if (hasTierMarker(toolInput)) {
   138	      return 0;
   139	    }
   140	
   141	    const generationModel = stateLib.modelForTier(root, "generation", "claude") || "generation";
   142	    const reason =
   143	      "bee-model-guard: every Agent/Task dispatch needs an explicit tier — a `model` " +
   144	      "param or a `[bee-tier: <tier>]` marker in the prompt/description (decision 0023). " +
   145	      "A bare dispatch would silently inherit the most expensive session model.\n" +
   146	      `FIX: pass model: "${generationModel}" for the generation tier, or add ` +
   147	      "[bee-tier: ceiling] (or another tier: generation/extraction/review) to the prompt/description.";
   148	    denial = { reason, toolInput };
   149	  } catch (error) {
   150	    logCrash(root, error);
   151	    return 0;
   152	  }
   153	
   154	  if (denial) {
   155	    logDeny(root, toolName, denial.toolInput);
   156	    // Deliberate deny: exit 2 with the reason on stderr (Claude Code feeds
   157	    // stderr back to the model on PreToolUse exit 2).
   158	    process.stderr.write(denial.reason);
   159	    return 2;
   160	  }
   161	  return 0;
   162	}
   163	
   164	process.exitCode = await main();
