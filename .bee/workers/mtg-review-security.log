skills/bee-hive/scripts/onboard_bee.mjs-1-#!/usr/bin/env node
skills/bee-hive/scripts/onboard_bee.mjs-2-// onboard_bee.mjs - install/update bee in a target repo.
skills/bee-hive/scripts/onboard_bee.mjs-3-//
skills/bee-hive/scripts/onboard_bee.mjs:4://   node onboard_bee.mjs --repo-root <path> [--apply] [--json] [--repo-hooks]
skills/bee-hive/scripts/onboard_bee.mjs-5-//                        [--claude-md] [--force-downgrade]
skills/bee-hive/scripts/onboard_bee.mjs-6-//
skills/bee-hive/scripts/onboard_bee.mjs-7-// Plan mode (default) reports {status: 'up_to_date'|'changes_needed'|
skills/bee-hive/scripts/onboard_bee.mjs-8-// 'blocked_downgrade'|'blocked_no_source', plan:[...]}.
skills/bee-hive/scripts/onboard_bee.mjs-9-// --apply applies the plan and writes .bee/onboarding.json with managed versions.
skills/bee-hive/scripts/onboard_bee.mjs-10-// Every apply also mirrors the bee-* skill set into the user's global
skills/bee-hive/scripts/onboard_bee.mjs-11-// ~/.claude/skills (D1-D5): drift shows up as sync_skill/remove_skill plan
skills/bee-hive/scripts/onboard_bee.mjs-12-// items, an older source refuses with zero mutations (--force-downgrade
skills/bee-hive/scripts/onboard_bee.mjs-13-// overrides only a fully-resolved version refusal), and non-bee skills are
skills/bee-hive/scripts/onboard_bee.mjs-14-// structurally untouchable.
skills/bee-hive/scripts/onboard_bee.mjs:15:// --repo-hooks additionally vendors the plugin hooks into <repo>/.bee/bin/hooks/
skills/bee-hive/scripts/onboard_bee.mjs-16-// and merges the 6 hook entries into <repo>/.claude/settings.json (with a .bak
skills/bee-hive/scripts/onboard_bee.mjs-17-// backup) for environments that do not load plugin hooks.
skills/bee-hive/scripts/onboard_bee.mjs-18-//
skills/bee-hive/scripts/onboard_bee.mjs-19-// Never overwrites existing .bee/state.json, .bee/decisions.jsonl, or .bee/cells/.
